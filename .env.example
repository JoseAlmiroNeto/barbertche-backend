PORT=3333
JWT_SECRET="use-at-least-32-random-characters"

# Local Docker PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/barbertche?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/barbertche?schema=public"

# Supabase PostgreSQL
# Use DATABASE_URL for the pooled/runtime connection.
# Use DIRECT_URL for migrations and Prisma direct access.
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=public"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require&schema=public"

# Initial admin user
ADMIN_NAME=""
ADMIN_EMAIL=""
ADMIN_PHONE=""
ADMIN_PASSWORD=""

# Supabase Storage for uploaded portfolio/product images
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET=""

# Optional when Expo push security is enabled in the EAS dashboard.
EXPO_ACCESS_TOKEN=""

# Time zone used to schedule 24-hour appointment reminders.
APP_TIME_ZONE="America/Sao_Paulo"
